{
    "version": 2,
    "buildCommand": "npm run build:frontend",
    "outputDirectory": "frontend/dist",
    "env": {
        "NODE_ENV": "production"
    },
    "builds": [
        {
            "src": "backend/app.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/uploads/(.*)",
            "dest": "/backend/app.js"
        },
        {
            "src": "/api/(.*)",
            "dest": "/backend/app.js"
        },
        {
            "src": "/(.*\\.(js|css|png|jpg|jpeg|svg|ico|woff|woff2|ttf|map))",
            "dest": "/frontend/dist/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/backend/app.js"
        }
    ]
}